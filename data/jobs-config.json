{
  "_help": "이 파일을 편집해서 회사/필터를 추가/제거하세요. fetcher: greenhouse-api | next-data | playwright",
  "filters": {
    "include": [
      "backend", "back-end", "백엔드",
      "server", "서버",
      "architect", "아키텍트", "아키텍처",
      "software engineer", "software developer",
      "platform", "플랫폼",
      "infra", "infrastructure", "인프라",
      "sre", "site reliability",
      "system", "시스템 엔지니어",
      "java", "kotlin", "spring",
      "api", "msa", "microservice"
    ],
    "exclude": [
      "frontend", "front-end", "프론트엔드",
      "ios", "android", "mobile", "모바일",
      "designer", "디자이너", "디자인",
      "marketing", "마케팅", "마케터",
      "sales", "세일즈", "영업",
      "hr", "hrbp", "인사", "총무",
      "legal", "법무", "변호사",
      "finance", "재무", "회계", "세무",
      "content", "콘텐츠", "creative", "크리에이티브",
      "qa", "qe", "test engineer",
      "데이터 분석가", "data analyst"
    ]
  },
  "companies": [
    {
      "id": "daangn",
      "name": "당근",
      "fetcher": "greenhouse-api",
      "params": { "board": "daangn" },
      "enabled": true
    },
    {
      "id": "autoever",
      "name": "현대오토에버",
      "fetcher": "playwright",
      "params": {
        "url": "https://career.hyundai-autoever.com/ko/apply?careers=EXPERIENCED&employments=FULL_TIME_WORKER",
        "extractNextData": true,
        "matchKeys": ["title", "dueDate"]
      },
      "enabled": true
    },
    {
      "id": "toss",
      "name": "토스",
      "fetcher": "playwright",
      "params": {
        "url": "https://toss.im/career/jobs",
        "selector": "a[href*=\"/career/job-detail\"]",
        "scrollPasses": 8
      },
      "enabled": true
    },
    {
      "id": "kakao",
      "name": "카카오",
      "fetcher": "playwright",
      "params": {
        "url": "https://careers.kakao.com/jobs?part=TECHNOLOGY&keyword=&employeeType=&page=1",
        "selector": "a[href*=\"/jobs/\"]",
        "scrollPasses": 6
      },
      "enabled": true
    },
    {
      "id": "naver",
      "name": "네이버",
      "fetcher": "playwright",
      "params": {
        "url": "https://recruit.navercorp.com/rcrt/list.do?annoId=&sw=&subJobCdData=1010001%2C1010002%2C1010003%2C1010005%2C1010008%2C1010020&sysCompanyCdData=&jobCdData=1010",
        "selector": "a",
        "filterByText": "모집 부서",
        "scrollPasses": 6
      },
      "enabled": true
    },
    {
      "id": "lgcns",
      "name": "LG CNS",
      "fetcher": "playwright",
      "params": {
        "url": "https://careers.lg.com/apply?c=CNS",
        "parseFromBodyText": true,
        "scrollPasses": 8
      },
      "enabled": true
    },
    {
      "id": "lguplus",
      "name": "LG U+",
      "fetcher": "playwright",
      "params": {
        "url": "https://careers.lg.com/channel/detail/lgu/job_openings",
        "selector": "a[href*=\"/apply/detail\"]",
        "scrollPasses": 6,
        "reloadOnFirstLoad": true
      },
      "enabled": true
    },
    {
      "id": "hyundai",
      "name": "현대자동차",
      "fetcher": "playwright",
      "params": {
        "url": "https://talent.hyundai.com/apply/applyList.hc?occupDataTagArray=211",
        "parseFromBodyText": true,
        "scrollPasses": 5
      },
      "enabled": true
    },
    {
      "id": "cj",
      "name": "CJ (올리브영/올네/대한통운)",
      "fetcher": "playwright",
      "params": {
        "url": "https://recruit.cj.net/recruit/ko/recruit/recruit/list.fo",
        "parseFromBodyText": true,
        "scrollPasses": 6,
        "clickFilters": ["IT", "경력"]
      },
      "enabled": true
    }
  ]
}
